#!/usr/bin/env python3
"""
Deckard MCP Server — exposes app control tools to the master Claude Code session.
Communicates with the Deckard app via its Unix domain socket.
Speaks MCP protocol (JSON-RPC over stdio).
"""
import json
import os
import socket
import sys

SOCKET_PATH = os.environ.get("DECKARD_SOCKET_PATH", "")

def send_to_deckard(message: dict) -> dict:
    """Send a JSON message to Deckard's control socket and return the response."""
    if not SOCKET_PATH or not os.path.exists(SOCKET_PATH):
        return {"ok": False, "error": "Deckard socket not available"}
    try:
        sock = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
        sock.settimeout(5)
        sock.connect(SOCKET_PATH)
        sock.sendall(json.dumps(message).encode() + b"\n")
        data = sock.recv(65536)
        sock.close()
        return json.loads(data.decode())
    except Exception as e:
        return {"ok": False, "error": str(e)}

def read_tab_content(surface_id: str, lines: int = 30) -> str:
    """Read visible terminal content from a tab via ghostty surface."""
    # For now, we return what we can get from the session files
    resp = send_to_deckard({"command": "get-tab-content", "surfaceId": surface_id})
    return resp.get("content", resp.get("error", "Content not available yet"))

# MCP Protocol Implementation

TOOLS = [
    {
        "name": "list_tabs",
        "description": "List all open tabs with their status, name, session ID, badge state, and working directory.",
        "inputSchema": {"type": "object", "properties": {}, "required": []}
    },
    {
        "name": "create_tab",
        "description": "Create a new Claude Code session tab.",
        "inputSchema": {
            "type": "object",
            "properties": {
                "working_directory": {"type": "string", "description": "Directory to open the session in"},
                "name": {"type": "string", "description": "Tab display name"}
            }
        }
    },
    {
        "name": "create_terminal_tab",
        "description": "Create a new plain terminal tab (not Claude Code).",
        "inputSchema": {
            "type": "object",
            "properties": {
                "working_directory": {"type": "string", "description": "Directory to open in"},
                "name": {"type": "string", "description": "Tab display name"}
            }
        }
    },
    {
        "name": "rename_tab",
        "description": "Rename a tab. Use this to give tabs descriptive names based on what the session is doing.",
        "inputSchema": {
            "type": "object",
            "properties": {
                "tab_id": {"type": "string", "description": "The tab UUID"},
                "name": {"type": "string", "description": "New display name (2-5 words)"}
            },
            "required": ["tab_id", "name"]
        }
    },
    {
        "name": "close_tab",
        "description": "Close a tab by its ID.",
        "inputSchema": {
            "type": "object",
            "properties": {
                "tab_id": {"type": "string", "description": "The tab UUID to close"}
            },
            "required": ["tab_id"]
        }
    },
    {
        "name": "focus_tab",
        "description": "Switch focus to a specific tab.",
        "inputSchema": {
            "type": "object",
            "properties": {
                "tab_id": {"type": "string", "description": "The tab UUID to focus"}
            },
            "required": ["tab_id"]
        }
    },
    {
        "name": "get_tab_status",
        "description": "Get detailed status of a specific tab including its badge state and session info.",
        "inputSchema": {
            "type": "object",
            "properties": {
                "tab_id": {"type": "string", "description": "The tab UUID"}
            },
            "required": ["tab_id"]
        }
    },
]

def handle_tool_call(name: str, arguments: dict) -> str:
    """Execute a tool call and return the result as text."""
    if name == "list_tabs":
        resp = send_to_deckard({"command": "list-tabs"})
        if resp.get("ok") and resp.get("tabs"):
            lines = []
            for t in resp["tabs"]:
                badge = t.get("badgeState", "none")
                sid = t.get("sessionId", "none")
                lines.append(f"- {t['name']} (id={t['id']}, badge={badge}, session={sid}, dir={t.get('workingDirectory', '?')})")
            return "\n".join(lines)
        return "No tabs open."

    elif name == "create_tab":
        resp = send_to_deckard({
            "command": "create-tab",
            "workingDirectory": arguments.get("working_directory"),
            "name": arguments.get("name"),
            "value": "claude"
        })
        return "Tab created." if resp.get("ok") else f"Error: {resp.get('error')}"

    elif name == "create_terminal_tab":
        resp = send_to_deckard({
            "command": "create-tab",
            "workingDirectory": arguments.get("working_directory"),
            "name": arguments.get("name"),
            "value": "terminal"
        })
        return "Terminal tab created." if resp.get("ok") else f"Error: {resp.get('error')}"

    elif name == "rename_tab":
        resp = send_to_deckard({
            "command": "rename-tab",
            "tabId": arguments["tab_id"],
            "name": arguments["name"]
        })
        return "Tab renamed." if resp.get("ok") else f"Error: {resp.get('error')}"

    elif name == "close_tab":
        resp = send_to_deckard({
            "command": "close-tab",
            "tabId": arguments["tab_id"]
        })
        return "Tab closed." if resp.get("ok") else f"Error: {resp.get('error')}"

    elif name == "focus_tab":
        resp = send_to_deckard({
            "command": "focus-tab",
            "tabId": arguments["tab_id"]
        })
        return "Tab focused." if resp.get("ok") else f"Error: {resp.get('error')}"

    elif name == "get_tab_status":
        resp = send_to_deckard({"command": "list-tabs"})
        if resp.get("ok") and resp.get("tabs"):
            for t in resp["tabs"]:
                if t["id"] == arguments["tab_id"]:
                    return json.dumps(t, indent=2)
        return "Tab not found."

    return f"Unknown tool: {name}"


def send_response(id, result):
    msg = {"jsonrpc": "2.0", "id": id, "result": result}
    out = json.dumps(msg)
    sys.stdout.write(f"Content-Length: {len(out)}\r\n\r\n{out}")
    sys.stdout.flush()

def send_error(id, code, message):
    msg = {"jsonrpc": "2.0", "id": id, "error": {"code": code, "message": message}}
    out = json.dumps(msg)
    sys.stdout.write(f"Content-Length: {len(out)}\r\n\r\n{out}")
    sys.stdout.flush()

_stdin_buffer = ""

def read_message():
    """Read a JSON-RPC message from stdin using Content-Length framing."""
    global _stdin_buffer

    # Read headers
    headers = {}
    while True:
        line = sys.stdin.readline()
        if not line:
            return None
        line = line.rstrip("\r\n")
        if line == "":
            break
        if ":" in line:
            key, val = line.split(":", 1)
            headers[key.strip()] = val.strip()

    length = int(headers.get("Content-Length", 0))
    if length == 0:
        return None

    # Read exactly `length` bytes
    body = ""
    while len(body) < length:
        chunk = sys.stdin.read(length - len(body))
        if not chunk:
            return None
        body += chunk

    return json.loads(body)

def main():
    while True:
        msg = read_message()
        if msg is None:
            break

        method = msg.get("method", "")
        id = msg.get("id")
        params = msg.get("params", {})

        if method == "initialize":
            send_response(id, {
                "protocolVersion": "2024-11-05",
                "capabilities": {"tools": {}},
                "serverInfo": {"name": "deckard", "version": "0.1.5"}
            })

        elif method == "notifications/initialized":
            pass  # No response needed

        elif method == "tools/list":
            send_response(id, {"tools": TOOLS})

        elif method == "tools/call":
            tool_name = params.get("name", "")
            arguments = params.get("arguments", {})
            result_text = handle_tool_call(tool_name, arguments)
            send_response(id, {
                "content": [{"type": "text", "text": result_text}]
            })

        elif method == "ping":
            send_response(id, {})

        else:
            if id is not None:
                send_error(id, -32601, f"Method not found: {method}")

if __name__ == "__main__":
    main()
